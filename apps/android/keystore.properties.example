# Copy to `keystore.properties` (gitignored) to sign release builds / the Play upload bundle.
# app/build.gradle.kts reads these; if the file is absent, release builds stay unsigned.
#
# For PLAY: generate a dedicated, SECRET upload key (do NOT reuse the debug cert) and enroll in
# Play App Signing (Google then holds the real app-signing key; this key only authorises uploads):
#
#   keytool -genkeypair -v -keystore pp-upload.jks -alias upload \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# Keep pp-upload.jks + these passwords OUT of git (store in _special-project/, chmod 600).

storeFile=/absolute/path/to/pp-upload.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME

# Build the Play bundle:  ./gradlew :app:bundleRelease
#   -> app/build/outputs/bundle/release/app-release.aab  (upload this to Play)
